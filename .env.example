# =====================================================================
# Docker Compose 环境变量模板（CLAUDE.md §16.2）
# 复制为 .env 后填入真实值，.env 已在 .gitignore 中
# =====================================================================

# 数据库
DB_PASSWORD=hya20050514
DB_NAME=Random
DB_PORT=3306

# Redis
REDIS_PORT=6379

# 后端服务端口
BACKEND_PORT=8080

# 讯飞星火（必须从 https://console.xfyun.cn 获取 APIPassword，对应具体模型版本）
# 主备切换：primary 用完/出错时切到 secondary；secondary 留空 = 单 key 行为
SPARK_API_PASSWORD_PRIMARY=your_api_password_here
SPARK_API_PASSWORD_SECONDARY=
SPARK_HOST=spark-api-open.xf-yun.com
SPARK_MODEL=generalv3.5